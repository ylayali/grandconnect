{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "grandconnect",
  "compatibility_date": "2026-04-24",
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".next",
    "binding": "ASSETS"
  }
}